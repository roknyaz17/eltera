# Скопируйте этот файл в .env и при необходимости измените значения.

# По умолчанию используется SQLite (запускается без установки СУБД).
DATABASE_URL=sqlite+aiosqlite:///./candidates.db

# Пример для PostgreSQL (раскомментируйте и укажите свои данные):
# DATABASE_URL=postgresql+asyncpg://eltera:eltera@localhost:5432/eltera

APP_NAME=Eltera Candidates API
DEBUG=true

# Источники, которым разрешён доступ к API (CORS). JSON-массив.
CORS_ORIGINS=["*"]

# Глобальный выключатель ИИ. false — ИИ не вызывается вообще
# (детерминированный fallback / «Доделать»), даже если задан ключ.
AI_ENABLED=true

# AI (OpenAI-совместимый провайдер): оценка открытых ответов и генерация
# нарратива отчёта. Без ключа — детерминированный fallback / «Доделать».
# OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# Базовый URL OpenAI-совместимого API.
# Timeweb Cloud AI (агент DeepSeek) — эндпоинт агента (с /v1 на конце):
# OPENAI_BASE_URL=https://agent.timeweb.cloud/api/v1/cloud-ai/agents/9093899c-b4f8-49d6-b857-5eed5315254e/v1
# Пусто — используется стандартный api.openai.com.
# OPENAI_BASE_URL=

# Telegram-бот для обращений из раздела «Поддержка».
# Токен — у @BotFather, chat_id — у @getidsbot (для группы — со знаком минус).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# SMTP для писем-приглашений на оценку / адаптацию / 360.
# Без SMTP_HOST и SMTP_FROM письма не отправляются (пишутся в лог).
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=hr@company.ru
# SMTP_PASSWORD=app-password
# SMTP_FROM=Eltera <hr@company.ru>
# SMTP_TLS=false        # STARTTLS (порт 587)
# SMTP_SSL=true         # прямой SSL (порт 465)
# APP_PUBLIC_URL=https://hr.company.ru   # из него строятся ссылки в письмах

# HeadHunter OAuth (вкладка «Вакансии»). Приложение: https://dev.hh.ru/admin
# HH_CLIENT_ID=...
# HH_CLIENT_SECRET=...
# HH_REDIRECT_URI=http://localhost:8000/api/hh/callback   # = Redirect URI в приложении HH
# HH_USER_AGENT=Eltera/1.0 (you@company.ru)

# Платёжный провайдер MONETA.RU / PayAnyWay (пополнение баланса оценок).
# Реквизиты — в кабинете магазина. Без MONETA_ACCOUNT_ID и MONETA_INTEGRITY_CODE
# оплата работает в демо-режиме (имитация без реального провайдера).
# В кабинете магазина пропишите Pay URL и Check URL:
#   {MONETA_PUBLIC_URL}/api/billing/moneta/callback
# MONETA_ACCOUNT_ID=20054600817
# MONETA_INTEGRITY_CODE=секретный-код-проверки-целостности
# MONETA_TEST_MODE=true   # false — боевой режим с реальными списаниями
# Боевая форма: https://www.payanyway.ru/assistant.htm ; демо: https://demo.moneta.ru/assistant.htm
# MONETA_ASSISTANT_URL=https://www.payanyway.ru/assistant.htm
# MONETA_CURRENCY=RUB
# MONETA_PUBLIC_URL=http://localhost:8000   # публичный адрес бэкенда для webhook
